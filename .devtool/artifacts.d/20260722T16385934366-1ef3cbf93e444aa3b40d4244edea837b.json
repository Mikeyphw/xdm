        {
          "command": "python3 - <<'PY'\nimport xml.etree.ElementTree as ET\nET.parse('app/src/main/AndroidManifest.xml')\nPY",
          "working_directory": "app/XDM.Android"
        },
        {
          "command": "python3 - <<'PY'\nfrom pathlib import Path\ntext = Path('app/src/main/kotlin/com/mikeyphw/xdm/android/Screens.kt').read_text()\nneedle = '\\n}\\n\\n@Composable\\nprivate fun DownloadListControls'\nif needle not in text:\n    raise SystemExit('Screens.kt: OrganizationPowerToolsCard must close before DownloadListControls')\ncount = 0\nstate = 'code'\nescape = False\nfor line in text.splitlines():\n    chars = line + '\\n'\n    i = 0\n    while i < len(chars):\n        ch = chars[i]\n        nxt = chars[i + 1] if i + 1 < len(chars) else ''\n        if state == 'code':\n            if ch == '\"':\n                state = 'string'\n            elif ch == \"'\":\n                state = 'char'\n            elif ch == '/' and nxt == '/':\n                state = 'line_comment'\n                i += 1\n            elif ch == '/' and nxt == '*':\n                state = 'block_comment'\n                i += 1\n            elif ch == '{':\n                count += 1\n            elif ch == '}':\n                count -= 1\n                if count < 0:\n                    raise SystemExit('Screens.kt: extra closing brace')\n        elif state == 'string':\n            if escape:\n                escape = False\n            elif ch == '\\\\':\n                escape = True\n            elif ch == '\"':\n                state = 'code'\n        elif state == 'char':\n            if escape:\n                escape = False\n            elif ch == '\\\\':\n                escape = True\n            elif ch == \"'\":\n                state = 'code'\n        elif state == 'line_comment':\n            if ch == '\\n':\n                state = 'code'\n        elif state == 'block_comment':\n            if ch == '*' and nxt == '/':\n                state = 'code'\n                i += 1\n        i += 1\nif count != 0 or state != 'code':\n    raise SystemExit(f'Screens.kt: unbalanced Kotlin structure, balance={count}, state={state}')\nprint('Screens.kt structure validation passed')\nPY",
          "working_directory": "app/XDM.Android"
        },
