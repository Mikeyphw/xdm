{
  "project": {
    "name": "XDM Android",
    "package_id": "com.mikeyphw.xdm.android",
    "version": "0.6.0-beta01",
    "implemented_phases": [
      0,
      1,
      2,
      3,
      4,
      5,
      6
    ]
  },
  "database": {
    "version": 6,
    "migrations": [
      "1_to_2",
      "2_to_3",
      "3_to_4",
      "4_to_5",
      "5_to_6"
    ],
    "destination_permission_health": true
  },
  "execution": {
    "uidt": true,
    "foreground_service_fallback": true,
    "reboot_restore": true,
    "per_download_notification_actions": [
      "pause",
      "resume",
      "retry",
      "cancel",
      "mute"
    ]
  },
  "storage": {
    "mediastore": [
      "downloads",
      "movies",
      "music",
      "pictures",
      "documents"
    ],
    "saf_tree": true,
    "sd_card_via_saf": true,
    "app_private_staging": true,
    "persisted_uri_permissions": true,
    "conflict_policies": [
      "overwrite",
      "resume",
      "rename",
      "skip",
      "compare"
    ]
  },
  "next_phase": "7",
  "backend_ownership": {
    "physical_artifact_identity": true,
    "persistent_backend_instance_identity": true,
    "per_process_session_identity": true,
    "startup_reconciliation": true,
    "legacy_claim_policy": "quarantine",
    "generation_safe_adoption": true
  },
  "aria2_runtime": {
    "foundation": true,
    "primary_abi": "arm64-v8a",
    "packaged_binary_name": "libaria2c.so",
    "executable_location": "ApplicationInfo.nativeLibraryDir",
    "loopback_rpc_only": true,
    "random_installation_secret": true,
    "session_persistence": true,
    "managed_process_lifecycle": true,
    "diagnostic_smoke_probe": true,
    "production_task_creation": true,
    "next_slice": "phase_7_backend_strategy_and_migration",
    "operational_backend": true,
    "durable_gid_mapping": true,
    "paused_creation_before_ownership_attachment": true,
    "event_polling": true,
    "session_reconciliation": true,
    "ownership_generation_validation": true,
    "provisional_completion_verification": true,
    "official_runtime_version": "1.37.0",
    "release_payload_gate": true
  }
}
