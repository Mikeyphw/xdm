<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:XDM.App.Converters"
             x:Class="XDM.App.App"
             RequestedThemeVariant="Dark">
  <Application.Resources>
    <converters:InvariantDecimalStringConverter x:Key="InvariantDecimalStringConverter" />
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="/Assets/xdm-logo.ico" ToolTipText="Xtreme Download Manager">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Open XDM" Click="TrayOpen_Click" />
            <NativeMenuItem Header="Open compact window" Click="TrayMini_Click" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Bandwidth: unlimited" Click="TrayBandwidthUnlimited_Click" />
            <NativeMenuItem Header="Bandwidth: 1 MiB/s" Click="TrayBandwidth1MiB_Click" />
            <NativeMenuItem Header="Bandwidth: 5 MiB/s" Click="TrayBandwidth5MiB_Click" />
            <NativeMenuItem Header="Bandwidth: 10 MiB/s" Click="TrayBandwidth10MiB_Click" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Exit" Click="TrayExit_Click" />
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>
</Application>
