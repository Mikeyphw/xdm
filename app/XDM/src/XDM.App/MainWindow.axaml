<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="840"
        x:Class="XDM.App.MainWindow"
        Title="{Binding Localization[ui_xtreme_download_manager]}"
        Width="1280"
        Height="840"
        MinWidth="1000"
        MinHeight="680"
        Background="{DynamicResource XdmWindowBackground}"
        KeyDown="MainWindow_KeyDown"
        AutomationProperties.Name="{Binding Localization[ui_xtreme_download_manager]}">

  <Window.Resources>
    <SolidColorBrush x:Key="XdmWindowBackground" Color="#0E1116" />
    <SolidColorBrush x:Key="XdmPanelBackground" Color="#12171E" />
    <SolidColorBrush x:Key="XdmPanelAltBackground" Color="#151B23" />
    <SolidColorBrush x:Key="XdmInputBackground" Color="#171D25" />
    <SolidColorBrush x:Key="XdmSecondaryButtonBackground" Color="#1B212A" />
    <SolidColorBrush x:Key="XdmSelectedBackground" Color="#26354A" />
    <SolidColorBrush x:Key="XdmBorderBrush" Color="#202833" />
    <SolidColorBrush x:Key="XdmInputBorderBrush" Color="#273240" />
    <SolidColorBrush x:Key="XdmBrandBrush" Color="#4F8CFF" />
    <SolidColorBrush x:Key="XdmPrimaryForeground" Color="#F3F7FC" />
    <SolidColorBrush x:Key="XdmPrimarySoftForeground" Color="#F1F5FA" />
    <SolidColorBrush x:Key="XdmBodyForeground" Color="#E8EEF7" />
    <SolidColorBrush x:Key="XdmBodySoftForeground" Color="#E9EEF6" />
    <SolidColorBrush x:Key="XdmSecondaryForeground" Color="#DDE5F2" />
    <SolidColorBrush x:Key="XdmSecondarySoftForeground" Color="#BAC7D8" />
    <SolidColorBrush x:Key="XdmSecondaryDimForeground" Color="#C8D1DE" />
    <SolidColorBrush x:Key="XdmMutedForeground" Color="#7F8B9B" />
    <SolidColorBrush x:Key="XdmSubtleForeground" Color="#718095" />
    <SolidColorBrush x:Key="XdmSubtleDarkForeground" Color="#687586" />
    <SolidColorBrush x:Key="XdmSummaryForeground" Color="#8794A5" />
    <SolidColorBrush x:Key="XdmDisabledForeground" Color="#58739A" />
    <SolidColorBrush x:Key="XdmAccentForeground" Color="#8FB5FF" />
    <SolidColorBrush x:Key="XdmErrorForeground" Color="#FF8F8F" />
    <SolidColorBrush x:Key="XdmWarningForeground" Color="#F5C66A" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource XdmBrandBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="16,9" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="{DynamicResource XdmSecondaryButtonBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource XdmSecondaryForeground}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="13,8" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource XdmInputBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource XdmBodyForeground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource XdmInputBorderBrush}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="11,8" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="{DynamicResource XdmInputBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource XdmBodyForeground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource XdmInputBorderBrush}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="8,5" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="12,11" />
      <Setter Property="Margin" Value="0,2" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource XdmSelectedBackground}" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource XdmMutedForeground}" />
    </Style>
    <Style Selector="Window.high-contrast">
      <Setter Property="Background" Value="#000000" />
    </Style>
    <Style Selector="Window.high-contrast Border">
      <Setter Property="BorderBrush" Value="#FFFFFF" />
    </Style>
    <Style Selector="Window.high-contrast TextBlock">
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Window.high-contrast Button">
      <Setter Property="BorderBrush" Value="#FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Window.high-contrast TextBox">
      <Setter Property="Background" Value="#000000" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#FFFFFF" />
    </Style>
  </Window.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
  <LayoutTransformControl x:Name="UiScaleRoot">
  <Grid x:Name="MainLayout" ColumnDefinitions="228,*" KeyboardNavigation.TabNavigation="Continue">
    <Border Grid.Column="0"
            Background="{DynamicResource XdmPanelBackground}"
            BorderBrush="{DynamicResource XdmBorderBrush}"
            BorderThickness="0,0,1,0"
            Padding="16">
      <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Spacing="2" Margin="8,8,8,20">
          <TextBlock Text="{Binding Localization[ui_xdm]}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource XdmPrimaryForeground}" />
          <TextBlock Text="{Binding Localization[ui_avalonia_downloader]}" FontSize="12" Foreground="{DynamicResource XdmMutedForeground}" />
        </StackPanel>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Sections}"
                 AutomationProperties.Name="{Binding Localization[ui_application_sections]}"
                 AutomationProperties.AccessibilityView="Control"
                 SelectedItem="{Binding SelectedSection}"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="28,*">
                <TextBlock Text="{Binding Glyph}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource XdmAccentForeground}" />
                <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource XdmSecondaryForeground}" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Background="{DynamicResource XdmInputBackground}" CornerRadius="8" Padding="12" Margin="0,14,0,0">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding Localization[ui_browser_capture]}" FontWeight="SemiBold" Foreground="{DynamicResource XdmSecondaryForeground}" />
            <TextBlock Text="{Binding Localization[ui_authenticated_loopback_capture_plus_direct_hls_and_dash_media_probing]}" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" Margin="28,22,28,18">
      <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,18">
        <StackPanel Spacing="5">
          <TextBlock Text="{Binding CurrentTitle}" FontSize="27" FontWeight="Bold" Foreground="{DynamicResource XdmPrimaryForeground}" />
          <TextBlock Text="{Binding CurrentSummary}" Foreground="{DynamicResource XdmSummaryForeground}" />
        </StackPanel>
        <TextBlock x:Name="OperationStatusText" Grid.Column="1" Text="{Binding OperationMessage}" AutomationProperties.Name="{Binding Localization[ui_operation_status]}" AutomationProperties.LiveSetting="Polite" Foreground="{DynamicResource XdmAccentForeground}" VerticalAlignment="Center" MaxWidth="430" TextWrapping="Wrap" />
      </Grid>

      <Grid Grid.Row="1" RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
          <Border Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="10" Padding="15">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding Localization[ui_active]}" Classes="label" />
              <TextBlock Text="{Binding ActiveDownloadCount}" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource XdmPrimaryForeground}" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="10" Padding="15">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding Localization[ui_speed]}" Classes="label" />
              <TextBlock Text="{Binding AggregateSpeed}" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource XdmPrimaryForeground}" />
            </StackPanel>
          </Border>
          <Border Grid.Column="2" Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="10" Padding="15">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding Localization[ui_core]}" Classes="label" />
              <TextBlock Text="{Binding CoreStatus}" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource XdmPrimaryForeground}" />
            </StackPanel>
          </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,14,0,0">
          <Grid IsVisible="{Binding IsDownloadsVisible}" RowDefinitions="Auto,Auto,Auto,*">
            <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="14" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="2*,*,Auto,Auto" ColumnSpacing="9">
                  <TextBox x:Name="NewDownloadUrlsInput" AcceptsReturn="True" MinHeight="62" PlaceholderText="{Binding Localization[ui_one_or_more_http_https_urls]}" Text="{Binding NewDownloadUrls}" AutomationProperties.Name="{Binding Localization[ui_download_urls]}" />
                  <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_destination_folder]}" Text="{Binding DestinationFolder}" />
                  <Button Grid.Column="2" Classes="secondary" Content="{Binding Localization[ui_browse]}" Click="BrowseDestination_Click" />
                  <Button Grid.Column="3" Classes="primary" Content="{Binding Localization[ui_add]}" Command="{Binding AddDownloadCommand}" />
                </Grid>

                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="9">
                  <ComboBox ItemsSource="{Binding CategoryDefinitions}" SelectedItem="{Binding SelectedCategory}">
                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                  </ComboBox>
                  <ComboBox Grid.Column="1" ItemsSource="{Binding QueueDefinitions}" SelectedItem="{Binding SelectedQueue}">
                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                  </ComboBox>
                  <ComboBox Grid.Column="2" ItemsSource="{Binding DuplicateBehaviors}" SelectedItem="{Binding SelectedDuplicateBehavior}" />
                  <TextBox Grid.Column="3" PlaceholderText="{Binding Localization[ui_speed_limit_kb_s_0_unlimited]}" Text="{Binding SpeedLimitKbps}" />
                </Grid>

                <Expander Header="{Binding Localization[ui_request_details_and_authentication]}">
                  <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="9" RowSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_custom_filename_single_url_only]}" Text="{Binding CustomFileName}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_user_agent]}" Text="{Binding UserAgent}" />
                    <TextBox Grid.Row="1" PlaceholderText="{Binding Localization[ui_username]}" Text="{Binding Username}" />
                    <TextBox Grid.Row="1" Grid.Column="1" PlaceholderText="{Binding Localization[ui_password]}" PasswordChar="●" Text="{Binding Password}" />
                    <TextBox Grid.Row="2" AcceptsReturn="True" MinHeight="58" PlaceholderText="{Binding Localization[ui_headers_one_per_line_name_value]}" Text="{Binding RequestHeaders}" />
                    <StackPanel Grid.Row="2" Grid.Column="1" Spacing="9">
                      <TextBox PlaceholderText="{Binding Localization[ui_cookie_header]}" Text="{Binding Cookie}" />
                      <TextBox PlaceholderText="{Binding Localization[ui_referer]}" Text="{Binding Referer}" />
                    </StackPanel>
                  </Grid>
                </Expander>
              </StackPanel>
            </Border>

            <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="8" Margin="0,10">
              <Grid ColumnDefinitions="*,220" ColumnSpacing="9">
                <TextBox x:Name="DownloadSearchInput" PlaceholderText="{Binding Localization[ui_search_filename_url_destination_or_queue]}" Text="{Binding DownloadSearchText}" AutomationProperties.Name="{Binding Localization[ui_search_downloads]}" />
                <ComboBox Grid.Column="1" ItemsSource="{Binding DownloadStatusFilters}" SelectedItem="{Binding SelectedDownloadStatus}" />
              </Grid>
              <WrapPanel Grid.Row="1" Orientation="Horizontal">
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_pause]}" Command="{Binding PauseSelectedCommand}" IsEnabled="{Binding SelectedDownload.CanPause}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_resume]}" Command="{Binding ResumeSelectedCommand}" IsEnabled="{Binding SelectedDownload.CanResume}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_cancel]}" Command="{Binding CancelSelectedCommand}" IsEnabled="{Binding SelectedDownload.CanCancel}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_retry]}" Command="{Binding RetrySelectedCommand}" IsEnabled="{Binding SelectedDownload.CanResume}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_remove]}" Command="{Binding RemoveSelectedCommand}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_convert]}" Command="{Binding PrepareSelectedDownloadConversionCommand}" />
                <ComboBox Width="110" Margin="0,0,8,0" ItemsSource="{Binding DownloadPriorities}" SelectedItem="{Binding SelectedDownloadPriority}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_set_priority]}" Command="{Binding ApplySelectedDownloadPriorityCommand}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_earlier]}" Command="{Binding MoveSelectedDownloadEarlierCommand}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_later]}" Command="{Binding MoveSelectedDownloadLaterCommand}" />
                <Button Margin="12,0,8,0" Classes="secondary" Content="{Binding Localization[ui_select_visible]}" Command="{Binding SelectAllVisibleCommand}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_clear_selection]}" Command="{Binding ClearBulkSelectionCommand}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_pause_selected]}" Command="{Binding PauseBulkCommand}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_resume_selected]}" Command="{Binding ResumeBulkCommand}" />
                <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_cancel_selected]}" Command="{Binding CancelBulkCommand}" />
                <Button Classes="secondary" Content="{Binding Localization[ui_remove_selected]}" Command="{Binding RemoveBulkCommand}" />
              </WrapPanel>
            </Grid>


            <Expander Grid.Row="2" Header="{Binding Localization[ui_history_and_file_management]}" Margin="0,0,0,10">
              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="14" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="9">
                  <WrapPanel Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_open_file]}" Command="{Binding OpenSelectedFileCommand}" />
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_open_folder]}" Command="{Binding RevealSelectedDestinationCommand}" />
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_open_url]}" Command="{Binding OpenSelectedSourceCommand}" />
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_open_source_page]}" Command="{Binding OpenSelectedSourcePageCommand}" IsEnabled="{Binding SelectedDownload.HasSourcePage}" />
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_re_download]}" Command="{Binding RedownloadSelectedCommand}" />
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_delete_partial_data]}" Command="{Binding DeleteSelectedPartialDataCommand}" />
                    <Button Classes="secondary" Content="{Binding Localization[ui_delete_file_history]}" Command="{Binding DeleteSelectedFileAndHistoryCommand}" />
                  </WrapPanel>
                  <Grid ColumnDefinitions="2*,2*,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_replacement_download_url]}" Text="{Binding RefreshedDownloadUrl}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_source_page_url_optional]}" Text="{Binding RefreshedSourcePage}" />
                    <Button Grid.Column="2" Classes="secondary" Content="{Binding Localization[ui_refresh_url]}" Command="{Binding RefreshSelectedDownloadUrlCommand}" />
                  </Grid>
                  <Grid ColumnDefinitions="2*,Auto,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_new_full_destination_path]}" Text="{Binding RelocationDestinationPath}" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_choose_path]}" Click="BrowseRelocationDestination_Click" />
                    <Button Grid.Column="2" Classes="secondary" Content="{Binding Localization[ui_move_rename]}" Command="{Binding RelocateSelectedDownloadCommand}" />
                  </Grid>
                  <CheckBox Content="{Binding Localization[ui_allow_replacing_an_existing_destination_file]}" IsChecked="{Binding OverwriteRelocationDestination}" />
                  <Grid ColumnDefinitions="2*,Auto,Auto,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_download_list_json_or_plain_url_list_path]}" Text="{Binding HistoryTransferPath}" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_choose_import]}" Click="BrowseHistoryImport_Click" />
                    <Button Grid.Column="2" Classes="secondary" Content="{Binding Localization[ui_choose_export]}" Click="BrowseHistoryExport_Click" />
                    <Button Grid.Column="3" Classes="secondary" Content="{Binding Localization[ui_import]}" Command="{Binding ImportDownloadListCommand}" />
                  </Grid>
                  <WrapPanel Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_export_visible]}" Command="{Binding ExportVisibleHistoryCommand}" />
                    <Button Classes="secondary" Content="{Binding Localization[ui_prune_now]}" Command="{Binding PruneHistoryCommand}" />
                  </WrapPanel>
                  <TextBlock Text="{Binding HistoryTransferStatus}" TextWrapping="Wrap" Foreground="{DynamicResource XdmAccentForeground}" />
                </StackPanel>
              </Border>
            </Expander>

            <Grid Grid.Row="3" ColumnDefinitions="2*,*" ColumnSpacing="12">
              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <ListBox ItemsSource="{Binding FilteredDownloads}"
                         SelectedItem="{Binding SelectedDownload}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="7">
                  <ListBox.ItemsPanel>
                    <ItemsPanelTemplate><VirtualizingStackPanel /></ItemsPanelTemplate>
                  </ListBox.ItemsPanel>
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="12" Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="8">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="16">
                          <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                          <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                            <TextBlock Text="{Binding Source}" FontSize="11" Foreground="{DynamicResource XdmSubtleForeground}" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <TextBlock Text="{Binding QueueId}" FontSize="10" Foreground="{DynamicResource XdmDisabledForeground}" />
                              <TextBlock Text="{Binding Priority}" FontSize="10" Foreground="{DynamicResource XdmAccentForeground}" />
                            </StackPanel>
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="{Binding StatusText}" Foreground="{DynamicResource XdmAccentForeground}" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="3" Text="{Binding SpeedText}" Foreground="{DynamicResource XdmSecondaryDimForeground}" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="4" Text="{Binding RemainingText}" Foreground="{DynamicResource XdmMutedForeground}" VerticalAlignment="Center" />
                          <ProgressBar Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,10,0,5" Height="5" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" />
                          <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ProgressText}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" />
                          <TextBlock Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3" Text="{Binding ErrorMessage}" FontSize="11" Foreground="{DynamicResource XdmErrorForeground}" HorizontalAlignment="Right" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>
              <Border Grid.Column="1" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="16" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
                  <TextBlock Text="{Binding Localization[ui_download_details]}" Classes="label" />
                  <StackPanel Grid.Row="1" Spacing="4">
                    <TextBlock Text="{Binding SelectedDownload.FileName}" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedDownload.Source}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedDownload.DestinationPath}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" TextWrapping="Wrap" />
                  </StackPanel>
                  <TextBlock Grid.Row="2" Text="{Binding Localization[ui_event_timeline]}" Classes="label" />
                  <ListBox Grid.Row="3" ItemsSource="{Binding SelectedDownloadTimeline}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate><VirtualizingStackPanel /></ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto" Margin="0,3">
                          <TextBlock Text="{Binding Status}" Foreground="{DynamicResource XdmAccentForeground}" FontSize="11" />
                          <TextBlock Grid.Column="1" Text="{Binding Timestamp}" Foreground="{DynamicResource XdmSubtleDarkForeground}" FontSize="10" HorizontalAlignment="Right" />
                          <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Message}" Foreground="{DynamicResource XdmSecondaryDimForeground}" FontSize="11" TextWrapping="Wrap" />
                        </Grid>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>
            </Grid>
          </Grid>

          <ScrollViewer IsVisible="{Binding IsQueuesVisible}">
            <StackPanel Spacing="14">
              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <TextBlock Text="{Binding Localization[ui_queue_definitions]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                  <ItemsControl ItemsSource="{Binding QueueDefinitions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{DynamicResource XdmInputBackground}" CornerRadius="8" Padding="12" Margin="0,0,0,7">
                          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="18">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource XdmBodyForeground}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                              <TextBlock Text="{Binding MaxConcurrentDownloads}" Foreground="{DynamicResource XdmAccentForeground}" />
                              <TextBlock Text="concurrent" Foreground="{DynamicResource XdmAccentForeground}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                              <TextBlock Text="{Binding SpeedLimitBytesPerSecond}" Foreground="{DynamicResource XdmMutedForeground}" />
                              <TextBlock Text="B/s limit" Foreground="{DynamicResource XdmMutedForeground}" />
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="{Binding QueueRuntimeStatus}" Foreground="{DynamicResource XdmAccentForeground}" TextWrapping="Wrap" />
                  <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="9">
                    <ComboBox ItemsSource="{Binding QueueDefinitions}" SelectedItem="{Binding SelectedQueue}">
                      <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="1" Classes="primary" Content="{Binding Localization[ui_start]}" Command="{Binding StartSelectedQueueCommand}" />
                    <Button Grid.Column="2" Classes="secondary" Content="{Binding Localization[ui_stop]}" Command="{Binding StopSelectedQueueCommand}" />
                    <Button Grid.Column="3" Classes="secondary" Content="{Binding Localization[ui_move_selected_download]}" Command="{Binding MoveSelectedDownloadToQueueCommand}" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_new_queue_name]}" Text="{Binding NewQueueName}" />
                    <Button Grid.Column="1" Classes="primary" Content="{Binding Localization[ui_add_queue]}" Command="{Binding AddQueueCommand}" />
                  </Grid>
                  <TextBlock Text="{Binding Localization[ui_queues_execute_independently_global_and_per_queue_concurrency_and_speed]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                </StackPanel>
              </Border>

              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <TextBlock Text="{Binding Localization[ui_categories]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                  <ItemsControl ItemsSource="{Binding CategoryDefinitions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{DynamicResource XdmInputBackground}" CornerRadius="8" Padding="12" Margin="0,0,0,7">
                          <Grid ColumnDefinitions="*,2*" ColumnSpacing="18">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource XdmBodyForeground}" />
                            <TextBlock Grid.Column="1" Text="{Binding DestinationDirectory}" Foreground="{DynamicResource XdmMutedForeground}" TextTrimming="CharacterEllipsis" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Grid ColumnDefinitions="*,*,2*,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_category_name]}" Text="{Binding NewCategoryName}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_extensions_zip_7z_rar]}" Text="{Binding NewCategoryExtensions}" />
                    <TextBox Grid.Column="2" PlaceholderText="{Binding Localization[ui_destination_blank_current]}" Text="{Binding NewCategoryDestination}" />
                    <Button Grid.Column="3" Classes="primary" Content="{Binding Localization[ui_add_category]}" Command="{Binding AddCategoryCommand}" />
                  </Grid>
                  <Button HorizontalAlignment="Left" Classes="secondary" Content="{Binding Localization[ui_save_definitions]}" Command="{Binding SaveSettingsCommand}" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer IsVisible="{Binding IsSchedulerVisible}">
            <StackPanel Spacing="14">
              <Grid ColumnDefinitions="320,*" ColumnSpacing="14">
                <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                  <StackPanel Spacing="10">
                    <TextBlock Text="{Binding Localization[ui_queue_schedules]}" Classes="label" />
                    <ListBox ItemsSource="{Binding Schedules}"
                             SelectedItem="{Binding SelectedSchedule}"
                             MinHeight="220"
                             MaxHeight="420">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Padding="10" Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="7">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                              <TextBlock Grid.Column="1" Text="{Binding Enabled}" Foreground="{DynamicResource XdmAccentForeground}" />
                              <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Queue.Name}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBox PlaceholderText="{Binding Localization[ui_new_schedule_name]}" Text="{Binding NewScheduleName}" />
                    <WrapPanel Orientation="Horizontal">
                      <Button Margin="0,0,8,0" Classes="primary" Content="{Binding Localization[ui_add_schedule]}" Command="{Binding AddScheduleCommand}" />
                      <Button Classes="secondary" Content="{Binding Localization[ui_remove]}" Command="{Binding RemoveSelectedScheduleCommand}" />
                    </WrapPanel>
                  </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                  <StackPanel Spacing="12" MaxWidth="820" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding Localization[ui_schedule_and_completion_workflow]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                    <TextBlock Text="{Binding SchedulerRuntimeStatus}" Foreground="{DynamicResource XdmAccentForeground}" TextWrapping="Wrap" />
                    <CheckBox Content="{Binding Localization[ui_enable_selected_schedule]}" IsChecked="{Binding SelectedSchedule.Enabled}" />
                    <TextBox PlaceholderText="{Binding Localization[ui_schedule_name]}" Text="{Binding SelectedSchedule.Name}" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="9">
                      <TextBox PlaceholderText="{Binding Localization[ui_start_hh_mm]}" Text="{Binding SelectedSchedule.StartTime}" />
                      <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_end_hh_mm]}" Text="{Binding SelectedSchedule.EndTime}" />
                      <ComboBox Grid.Column="2" ItemsSource="{Binding QueueDefinitions}" SelectedItem="{Binding SelectedSchedule.Queue}">
                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                      </ComboBox>
                    </Grid>
                    <TextBlock Text="{Binding Localization[ui_run_on_days]}" Classes="label" />
                    <WrapPanel Orientation="Horizontal">
                      <CheckBox Margin="0,0,10,0" Content="{Binding Localization[ui_mon]}" IsChecked="{Binding SelectedSchedule.MondayEnabled}" />
                      <CheckBox Margin="0,0,10,0" Content="{Binding Localization[ui_tue]}" IsChecked="{Binding SelectedSchedule.TuesdayEnabled}" />
                      <CheckBox Margin="0,0,10,0" Content="{Binding Localization[ui_wed]}" IsChecked="{Binding SelectedSchedule.WednesdayEnabled}" />
                      <CheckBox Margin="0,0,10,0" Content="{Binding Localization[ui_thu]}" IsChecked="{Binding SelectedSchedule.ThursdayEnabled}" />
                      <CheckBox Margin="0,0,10,0" Content="{Binding Localization[ui_fri]}" IsChecked="{Binding SelectedSchedule.FridayEnabled}" />
                      <CheckBox Margin="0,0,10,0" Content="{Binding Localization[ui_sat]}" IsChecked="{Binding SelectedSchedule.SaturdayEnabled}" />
                      <CheckBox Content="{Binding Localization[ui_sun]}" IsChecked="{Binding SelectedSchedule.SundayEnabled}" />
                    </WrapPanel>
                    <ComboBox ItemsSource="{Binding SelectedSchedule.MissedRunOptions}" SelectedItem="{Binding SelectedSchedule.MissedRunPolicy}" />
                    <TextBlock Text="{Binding Localization[ui_completion_action]}" Classes="label" />
                    <Grid ColumnDefinitions="2*,*" ColumnSpacing="9">
                      <ComboBox ItemsSource="{Binding SelectedSchedule.CompletionActionOptions}" SelectedItem="{Binding SelectedSchedule.CompletionAction}" />
                      <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_countdown_seconds]}" Text="{Binding SelectedSchedule.CountdownSeconds}" />
                    </Grid>
                    <TextBox PlaceholderText="{Binding Localization[ui_absolute_executable_path_for_runcommand]}" Text="{Binding SelectedSchedule.CommandPath}" />
                    <TextBox PlaceholderText="{Binding Localization[ui_one_command_argument_per_line]}" Text="{Binding SelectedSchedule.CommandArguments}" AcceptsReturn="True" MinHeight="72" />

                    <Border Background="{DynamicResource XdmInputBackground}" CornerRadius="8" Padding="12">
                      <StackPanel Spacing="8">
                        <TextBlock Text="{Binding Localization[ui_antivirus_scan_before_completion_action]}" Classes="label" />
                        <CheckBox Content="{Binding Localization[ui_scan_files_completed_by_scheduled_runs]}" IsChecked="{Binding AntivirusEnabled}" />
                        <TextBox PlaceholderText="{Binding Localization[ui_absolute_antivirus_executable_path]}" Text="{Binding AntivirusExecutablePath}" />
                        <TextBox PlaceholderText="{Binding Localization[ui_one_argument_per_line_use_file_where_the_file_path_belongs]}" Text="{Binding AntivirusArguments}" AcceptsReturn="True" MinHeight="62" />
                        <TextBox PlaceholderText="{Binding Localization[ui_scan_timeout_seconds]}" Text="{Binding AntivirusTimeoutSeconds}" />
                      </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding CompletionCapabilitySummary}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                    <TextBlock Text="{Binding PendingCompletionAction}" TextWrapping="Wrap" Foreground="{DynamicResource XdmWarningForeground}" />
                    <WrapPanel Orientation="Horizontal">
                      <Button Margin="0,0,8,0" Classes="primary" Content="{Binding Localization[ui_save_schedules]}" Command="{Binding SaveSettingsCommand}" />
                      <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_refresh_capabilities]}" Command="{Binding RefreshCompletionCapabilitiesCommand}" />
                      <Button Classes="secondary" Content="{Binding Localization[ui_cancel_pending_action]}" Command="{Binding CancelPendingCompletionActionCommand}" IsEnabled="{Binding HasPendingCompletionAction}" />
                    </WrapPanel>
                    <TextBlock Text="{Binding Localization[ui_commands_are_launched_directly_without_a_shell_shutdown_sleep_hibernate]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer IsVisible="{Binding IsBrowserIntegrationVisible}">
            <StackPanel Spacing="14">
              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="13" MaxWidth="820" HorizontalAlignment="Left">
                  <TextBlock Text="{Binding Localization[ui_browser_capture_service]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                  <TextBlock Text="{Binding BrowserIntegrationStatus}" Foreground="{DynamicResource XdmAccentForeground}" />
                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="14" RowSpacing="8">
                    <TextBlock Text="{Binding Localization[ui_endpoint]}" Classes="label" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding BrowserEndpoint}" IsReadOnly="True" />
                    <TextBlock Grid.Row="1" Text="{Binding Localization[ui_token]}" Classes="label" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BrowserAuthenticationToken}" IsReadOnly="True" />
                  </Grid>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Classes="primary" Content="{Binding Localization[ui_restart_capture_service]}" Command="{Binding RestartBrowserIntegrationCommand}" />
                    <Button Classes="secondary" Content="{Binding Localization[ui_probe_url_from_downloads]}" Command="{Binding ProbeEnteredUrlCommand}" />
                  </StackPanel>
                  <Border Background="{DynamicResource XdmInputBackground}" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding Localization[ui_native_host]}" Classes="label" />
                      <TextBlock Text="{Binding BrowserHostStatus}" TextWrapping="Wrap" Foreground="{DynamicResource XdmSecondarySoftForeground}" />
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <TextBox PlaceholderText="{Binding Localization[ui_chromium_extension_id_s_comma_separated_firefox_is_automatic]}" Text="{Binding BrowserExtensionId}" />
                        <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_install_repair]}" Command="{Binding RepairBrowserHostCommand}" />
                        <Button Grid.Column="2" Classes="secondary" Content="{Binding Localization[ui_uninstall]}" Command="{Binding UninstallBrowserHostCommand}" />
                      </Grid>
                    </StackPanel>
                  </Border>
                  <TextBlock Text="{Binding Localization[ui_browser_extensions_use_the_versioned_native_messaging_protocol_the_host]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                </StackPanel>
              </Border>
              <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                  <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Localization[ui_last_capture]}" Classes="label" />
                    <TextBlock Text="{Binding LastBrowserCapture}" TextWrapping="Wrap" Foreground="{DynamicResource XdmBodyForeground}" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                  <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Localization[ui_media_probe]}" Classes="label" />
                    <TextBlock Text="{Binding LastMediaProbe}" TextWrapping="Wrap" Foreground="{DynamicResource XdmBodyForeground}" />
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer IsVisible="{Binding IsMediaVisible}">
            <StackPanel Spacing="14">
              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="13">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_hls_dash_direct_media_or_a_page_supported_by_yt_dlp]}" Text="{Binding MediaSourceUrl}" />
                    <Button Grid.Column="1" Classes="primary" Content="{Binding Localization[ui_discover_formats]}" Command="{Binding ProbeMediaCommand}" />
                  </Grid>
                  <TextBlock Text="{Binding MediaCatalogSummary}" TextWrapping="Wrap" Foreground="{DynamicResource XdmAccentForeground}" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="9">
                    <TextBlock Text="{Binding MediaToolHealth}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_check_tools]}" Command="{Binding RefreshMediaToolHealthCommand}" />
                  </Grid>
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                  <StackPanel Spacing="10">
                    <TextBlock Text="{Binding Localization[ui_video]}" Classes="label" />
                    <ComboBox ItemsSource="{Binding MediaVideoFormats}" SelectedItem="{Binding SelectedMediaVideoFormat}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Margin="2" Spacing="2">
                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource XdmBodyForeground}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Details}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" />
                          </StackPanel>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                  <StackPanel Spacing="10">
                    <TextBlock Text="{Binding Localization[ui_audio]}" Classes="label" />
                    <ComboBox ItemsSource="{Binding MediaAudioFormats}" SelectedItem="{Binding SelectedMediaAudioFormat}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Margin="2" Spacing="2">
                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource XdmBodyForeground}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Details}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" />
                          </StackPanel>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                </Border>
              </Grid>

              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                  <TextBlock Text="{Binding Localization[ui_subtitles]}" Classes="label" />
                  <ItemsControl ItemsSource="{Binding MediaSubtitleFormats}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Margin="0,0,18,7" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="{Binding Localization[ui_selected_subtitles_are_saved_as_language_labelled_sidecar_files_separate]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                </StackPanel>
              </Border>

              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="11">
                  <Grid ColumnDefinitions="2*,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_destination_folder]}" Text="{Binding DestinationFolder}" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_browse]}" Click="BrowseDestination_Click" />
                  </Grid>
                  <Grid ColumnDefinitions="2*,*" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_output_filename_for_example_video_mp4]}" Text="{Binding MediaDestinationFile}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_live_capture_minutes]}" Text="{Binding MediaLiveDurationMinutes}" />
                  </Grid>
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <CheckBox Content="{Binding Localization[ui_queue_conversion_after_download]}" IsChecked="{Binding MediaPostConversionEnabled}" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1" ItemsSource="{Binding ConversionPresets}" SelectedItem="{Binding MediaPostConversionPreset}" IsEnabled="{Binding MediaPostConversionEnabled}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </Grid>
                  <ProgressBar Minimum="0" Maximum="1" Value="{Binding MediaDownloadProgress}" IsIndeterminate="{Binding MediaDownloadIndeterminate}" Height="6" />
                  <TextBlock Text="{Binding MediaDownloadStatus}" TextWrapping="Wrap" Foreground="{DynamicResource XdmSecondarySoftForeground}" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Classes="primary" Content="{Binding Localization[ui_download_selected_media]}" Command="{Binding DownloadMediaCommand}" />
                    <Button Classes="secondary" Content="{Binding Localization[ui_cancel]}" Command="{Binding CancelMediaDownloadCommand}" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer IsVisible="{Binding IsConversionVisible}">
            <StackPanel Spacing="14">
              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <StackPanel Spacing="5">
                      <TextBlock Text="{Binding Localization[ui_ffmpeg_conversion]}" Classes="label" />
                      <TextBlock Text="{Binding ConversionHealth}" TextWrapping="Wrap" Foreground="{DynamicResource XdmSecondarySoftForeground}" />
                    </StackPanel>
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_check_ffmpeg_ffprobe]}" Command="{Binding RefreshConversionHealthCommand}" />
                  </Grid>
                  <TextBlock Text="{Binding Localization[ui_preset_ids_select_fixed_argument_templates_xdm_never_executes_user_provi]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                </StackPanel>
              </Border>

              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="11">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_source_media_file]}" Text="{Binding ConversionSourcePath}" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_browse]}" Click="BrowseConversionSource_Click" />
                  </Grid>
                  <TextBox PlaceholderText="{Binding Localization[ui_destination_mp4_or_mp3_path]}" Text="{Binding ConversionDestinationPath}" />
                  <ComboBox ItemsSource="{Binding ConversionPresets}" SelectedItem="{Binding SelectedConversionPreset}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <StackPanel Margin="2" Spacing="2">
                          <TextBlock Text="{Binding Name}" Foreground="{DynamicResource XdmBodyForeground}" />
                          <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" TextWrapping="Wrap" />
                        </StackPanel>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <CheckBox Content="{Binding Localization[ui_overwrite_an_existing_destination_only_after_conversion_succeeds]}" IsChecked="{Binding ConversionOverwriteExisting}" />
                  <TextBlock Text="{Binding ConversionStatus}" TextWrapping="Wrap" Foreground="{DynamicResource XdmAccentForeground}" />
                  <Button HorizontalAlignment="Left" Classes="primary" Content="{Binding Localization[ui_add_to_conversion_queue]}" Command="{Binding EnqueueConversionCommand}" />
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="2*,*" ColumnSpacing="14" MinHeight="300">
                <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                  <ListBox ItemsSource="{Binding ConversionJobs}"
                           SelectedItem="{Binding SelectedConversionJob}"
                           Background="Transparent"
                           BorderThickness="0"
                           Padding="7">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate><VirtualizingStackPanel /></ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Padding="12" Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="8">
                          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel>
                              <TextBlock Text="{Binding PresetName}" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                              <TextBlock Text="{Binding SourcePath}" FontSize="11" Foreground="{DynamicResource XdmSubtleForeground}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding State}" Foreground="{DynamicResource XdmAccentForeground}" VerticalAlignment="Center" />
                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Margin="0,9,0,5" Height="5" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" IsIndeterminate="{Binding IsIndeterminate}" />
                            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" TextWrapping="Wrap" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OutputSize}" FontSize="11" Foreground="{DynamicResource XdmSecondarySoftForeground}" HorizontalAlignment="Right" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                  <StackPanel Spacing="10">
                    <TextBlock Text="{Binding Localization[ui_selected_job]}" Classes="label" />
                    <TextBlock Text="{Binding SelectedConversionJob.PresetName}" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                    <TextBlock Text="{Binding SelectedConversionJob.SourcePath}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedConversionJob.DestinationPath}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedConversionJob.ErrorMessage}" Foreground="{DynamicResource XdmErrorForeground}" TextWrapping="Wrap" />
                    <WrapPanel Orientation="Horizontal">
                      <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_cancel]}" Command="{Binding CancelSelectedConversionCommand}" IsEnabled="{Binding SelectedConversionJob.CanCancel}" />
                      <Button Classes="secondary" Content="{Binding Localization[ui_remove]}" Command="{Binding RemoveSelectedConversionCommand}" IsEnabled="{Binding SelectedConversionJob.CanRemove}" />
                    </WrapPanel>
                    <TextBlock Text="{Binding Localization[ui_conversions_run_one_at_a_time_cancellation_terminates_the_ffmpeg_process]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer IsVisible="{Binding IsSettingsVisible}">
            <StackPanel Spacing="14" MaxWidth="920" HorizontalAlignment="Left">
              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <TextBlock Text="{Binding Localization[ui_download_behavior]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                  <Grid ColumnDefinitions="2*,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_default_download_directory]}" Text="{Binding DestinationFolder}" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_browse]}" Click="BrowseDestination_Click" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_maximum_concurrent_downloads]}" Text="{Binding MaxConcurrentDownloads}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_default_speed_limit_kb_s_0_unlimited]}" Text="{Binding DefaultSpeedLimitKbps}" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*,*" ColumnSpacing="9">
                    <ComboBox ItemsSource="{Binding DuplicateBehaviors}" SelectedItem="{Binding SelectedDuplicateBehavior}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_default_connections]}" Text="{Binding DefaultConnectionCount}" />
                    <TextBox Grid.Column="2" PlaceholderText="{Binding Localization[ui_maximum_connections]}" Text="{Binding MaximumConnectionCount}" />
                  </Grid>
                  <CheckBox Content="{Binding Localization[ui_create_destination_directories_when_missing]}" IsChecked="{Binding CreateDestinationDirectory}" />
                  <CheckBox Content="{Binding Localization[ui_automatically_select_categories_by_extension]}" IsChecked="{Binding AutoSelectCategory}" />
                  <CheckBox Content="{Binding Localization[ui_remember_the_last_request_metadata_in_the_download_dialog]}" IsChecked="{Binding RememberLastRequestMetadata}" />
                  <CheckBox Content="{Binding Localization[ui_monitor_clipboard_for_http_https_links]}" IsChecked="{Binding ClipboardMonitoringEnabled}" />
                  <CheckBox Content="{Binding Localization[ui_automatically_add_links_captured_from_clipboard]}" IsChecked="{Binding AutoAddClipboardLinks}" />
                </StackPanel>
              </Border>


              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <TextBlock Text="{Binding Localization[ui_language_and_accessibility]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                  <Grid ColumnDefinitions="2*,*" ColumnSpacing="9">
                    <ComboBox ItemsSource="{Binding AvailableLanguages}" SelectedItem="{Binding SelectedLanguage}" AutomationProperties.Name="{Binding Localization[ui_interface_language]}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_ui_scale_percent_75_175]}" Text="{Binding UiScalePercent}" AutomationProperties.Name="{Binding Localization[ui_ui_scale_percent]}" />
                  </Grid>
                  <CheckBox Content="{Binding Localization[ui_use_the_operating_system_language]}" IsChecked="{Binding UseSystemLanguage}" />
                  <CheckBox Content="{Binding Localization[ui_use_high_contrast_colors]}" IsChecked="{Binding HighContrastEnabled}" />
                  <CheckBox Content="{Binding Localization[ui_announce_operation_status_changes_to_screen_readers]}" IsChecked="{Binding AnnounceStatusChanges}" />
                  <TextBlock Text="{Binding Localization[ui_language_right_to_left_layout_contrast_and_scaling_update_immediately_af]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                </StackPanel>
              </Border>


              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <TextBlock Text="{Binding Localization[ui_history_retention]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                  <CheckBox Content="{Binding Localization[ui_automatically_prune_terminal_history_entries]}" IsChecked="{Binding HistoryRetentionEnabled}" />
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_retention_days]}" Text="{Binding HistoryRetentionDays}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_maximum_history_entries]}" Text="{Binding HistoryMaximumEntries}" />
                  </Grid>
                  <TextBlock Text="{Binding Localization[ui_retention_removes_only_history_entries_downloaded_files_are_never_delete]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                </StackPanel>
              </Border>

              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <TextBlock Text="{Binding Localization[ui_network_retries_and_segmented_transfers]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                  <Grid ColumnDefinitions="*,*,*" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_connect_timeout_seconds]}" Text="{Binding ConnectTimeoutSeconds}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_whole_request_timeout_seconds_0_unlimited]}" Text="{Binding RequestTimeoutSeconds}" />
                    <TextBox Grid.Column="2" PlaceholderText="{Binding Localization[ui_maximum_retry_attempts]}" Text="{Binding MaximumRetryAttempts}" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_retry_base_delay_milliseconds]}" Text="{Binding RetryBaseDelayMilliseconds}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_minimum_segmented_size_mib]}" Text="{Binding MinimumSegmentedSizeMegabytes}" />
                  </Grid>
                  <TextBlock Text="{Binding Localization[ui_network_handler_proxy_retry_and_segment_settings_apply_to_new_processes]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                </StackPanel>
              </Border>

              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="3">
                      <TextBlock Text="{Binding Localization[ui_aria2_backend]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                      <TextBlock Text="{Binding Aria2ConnectionStatus}" TextWrapping="Wrap" Foreground="{DynamicResource XdmAccentForeground}" />
                    </StackPanel>
                    <ProgressBar Grid.Column="1" Width="90" Height="6" IsIndeterminate="{Binding Aria2IsRefreshing}" IsVisible="{Binding Aria2IsRefreshing}" />
                  </Grid>
                  <CheckBox Content="{Binding Localization[ui_enable_aria2_backend]}" IsChecked="{Binding Aria2Enabled}" />
                  <Grid ColumnDefinitions="*,2*,*" ColumnSpacing="9">
                    <ComboBox ItemsSource="{Binding Aria2ConnectionModes}" SelectedItem="{Binding SelectedAria2ConnectionMode}" AutomationProperties.Name="{Binding Localization[ui_aria2_connection_mode]}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_aria2_rpc_endpoint]}" Text="{Binding Aria2RpcEndpoint}" />
                    <TextBox Grid.Column="2" PlaceholderText="{Binding Localization[ui_aria2_rpc_secret]}" Text="{Binding Aria2RpcSecret}" PasswordChar="●" />
                  </Grid>
                  <Grid ColumnDefinitions="2*,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_aria2_executable_path]}" Text="{Binding Aria2ExecutablePath}" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_browse]}" Click="BrowseAria2Executable_Click" />
                  </Grid>
                  <Grid ColumnDefinitions="2*,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_aria2_session_file]}" Text="{Binding Aria2SessionFilePath}" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_browse]}" Click="BrowseAria2SessionFile_Click" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_aria2_poll_interval_ms]}" Text="{Binding Aria2PollIntervalMilliseconds}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_aria2_rpc_timeout_seconds]}" Text="{Binding Aria2RpcConnectTimeoutSeconds}" />
                    <TextBox Grid.Column="2" PlaceholderText="{Binding Localization[ui_aria2_max_concurrent]}" Text="{Binding Aria2MaxConcurrentDownloads}" />
                    <TextBox Grid.Column="3" PlaceholderText="{Binding Localization[ui_aria2_split_count]}" Text="{Binding Aria2SplitCount}" />
                  </Grid>
                  <TextBox PlaceholderText="{Binding Localization[ui_aria2_minimum_split_mib]}" Text="{Binding Aria2MinimumSplitSizeMegabytes}" />
                  <WrapPanel Orientation="Horizontal">
                    <CheckBox Margin="0,0,18,0" Content="{Binding Localization[ui_aria2_auto_start]}" IsChecked="{Binding Aria2AutoStartManagedProcess}" />
                    <CheckBox Margin="0,0,18,0" Content="{Binding Localization[ui_aria2_continue]}" IsChecked="{Binding Aria2ContinueDownloads}" />
                    <CheckBox Margin="0,0,18,0" Content="{Binding Localization[ui_aria2_check_certificate]}" IsChecked="{Binding Aria2CheckCertificate}" />
                    <CheckBox Content="{Binding Localization[ui_aria2_save_session]}" IsChecked="{Binding Aria2SaveSession}" />
                  </WrapPanel>
                  <TextBox AcceptsReturn="True" MinHeight="62" PlaceholderText="{Binding Localization[ui_aria2_additional_arguments]}" Text="{Binding Aria2AdditionalArguments}" />
                  <WrapPanel Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Classes="primary" Content="{Binding Localization[ui_apply_and_connect]}" Command="{Binding ApplyAria2ConfigurationCommand}" />
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_start_managed_aria2]}" Command="{Binding StartManagedAria2Command}" IsEnabled="{Binding CanStartManagedAria2}" />
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_stop_managed_aria2]}" Command="{Binding StopManagedAria2Command}" />
                    <Button Classes="secondary" Content="{Binding Localization[ui_refresh]}" Command="{Binding RefreshAria2Command}" />
                  </WrapPanel>
                  <TextBlock Text="{Binding Localization[ui_aria2_security_note]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />

                  <Border Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="8" Padding="12" Margin="0,4,0,0">
                    <StackPanel Spacing="9">
                      <TextBlock Text="{Binding Localization[ui_add_aria2_download]}" FontWeight="SemiBold" Foreground="{DynamicResource XdmSecondaryForeground}" />
                      <TextBox PlaceholderText="{Binding Localization[ui_aria2_url_or_magnet]}" Text="{Binding Aria2NewUrl}" />
                      <Grid ColumnDefinitions="2*,Auto,*" ColumnSpacing="9">
                        <TextBox PlaceholderText="{Binding Localization[ui_destination_folder]}" Text="{Binding Aria2DestinationFolder}" />
                        <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_browse]}" Click="BrowseAria2Destination_Click" />
                        <TextBox Grid.Column="2" PlaceholderText="{Binding Localization[ui_custom_filename_optional]}" Text="{Binding Aria2CustomFileName}" />
                      </Grid>
                      <Button HorizontalAlignment="Left" Classes="primary" Content="{Binding Localization[ui_add_to_aria2]}" Command="{Binding AddAria2DownloadCommand}" />
                    </StackPanel>
                  </Border>

                  <ListBox ItemsSource="{Binding Aria2Tasks}" SelectedItem="{Binding SelectedAria2Task}" MaxHeight="310">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="2*,Auto" ColumnSpacing="12" RowSpacing="5" Margin="2">
                          <StackPanel>
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{DynamicResource XdmBodyForeground}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding DestinationPath}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                          <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource XdmAccentForeground}" HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding SpeedText}" FontSize="11" Foreground="{DynamicResource XdmSecondarySoftForeground}" HorizontalAlignment="Right" />
                          </StackPanel>
                          <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" IsIndeterminate="{Binding IsIndeterminate}" Height="7" />
                          <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Text="{Binding ProgressText}" FontSize="11" Foreground="{DynamicResource XdmSecondarySoftForeground}" />
                            <TextBlock Grid.Column="1" Text="{Binding ConnectionsText, StringFormat='{}{0} connections'}" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" />
                          </Grid>
                        </Grid>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <WrapPanel Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_pause]}" Command="{Binding PauseSelectedAria2TaskCommand}" IsEnabled="{Binding SelectedAria2Task.CanPause}" />
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_resume]}" Command="{Binding ResumeSelectedAria2TaskCommand}" IsEnabled="{Binding SelectedAria2Task.CanResume}" />
                    <Button Classes="secondary" Content="{Binding Localization[ui_remove]}" Command="{Binding RemoveSelectedAria2TaskCommand}" IsEnabled="{Binding SelectedAria2Task.CanRemove}" />
                  </WrapPanel>
                </StackPanel>
              </Border>

              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <TextBlock Text="{Binding Localization[ui_proxy]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                  <Grid ColumnDefinitions="*,2*,*" ColumnSpacing="9">
                    <ComboBox ItemsSource="{Binding ProxyModes}" SelectedItem="{Binding SelectedProxyMode}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_proxy_host]}" Text="{Binding ProxyHost}" />
                    <TextBox Grid.Column="2" PlaceholderText="{Binding Localization[ui_port]}" Text="{Binding ProxyPort}" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*,*" ColumnSpacing="9">
                    <ComboBox ItemsSource="{Binding ProxyAuthenticationModes}" SelectedItem="{Binding SelectedProxyAuthenticationMode}" AutomationProperties.Name="{Binding Localization[ui_proxy_authentication_mode]}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_proxy_username]}" Text="{Binding ProxyUsername}" />
                    <TextBox Grid.Column="2" PlaceholderText="{Binding Localization[ui_proxy_password]}" Text="{Binding ProxyPassword}" PasswordChar="●" />
                  </Grid>
                  <TextBox PlaceholderText="{Binding Localization[ui_pac_url_http_https_or_file]}" Text="{Binding ProxyAutomaticConfigurationUrl}" />
                  <TextBlock Text="{Binding Localization[ui_integrated_proxy_authentication_note]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                  <CheckBox Content="{Binding Localization[ui_bypass_proxy_for_local_addresses]}" IsChecked="{Binding ProxyBypassLocal}" />
                  <TextBox AcceptsReturn="True" MinHeight="70" PlaceholderText="{Binding Localization[ui_proxy_bypass_patterns_one_per_line]}" Text="{Binding ProxyBypassList}" />
                </StackPanel>
              </Border>

              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <TextBlock Text="{Binding Localization[ui_server_credentials]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                  <Grid ColumnDefinitions="2*,*,*" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_host_example_com]}" Text="{Binding CredentialHost}" />
                    <TextBox Grid.Column="1" PlaceholderText="{Binding Localization[ui_username]}" Text="{Binding CredentialUsername}" />
                    <TextBox Grid.Column="2" PlaceholderText="{Binding Localization[ui_password]}" Text="{Binding CredentialPassword}" PasswordChar="●" />
                  </Grid>
                  <CheckBox Content="{Binding Localization[ui_include_subdomains]}" IsChecked="{Binding CredentialIncludesSubdomains}" />
                  <WrapPanel Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_add_or_replace]}" Command="{Binding AddServerCredentialCommand}" />
                    <Button Classes="secondary" Content="{Binding Localization[ui_remove_selected]}" Command="{Binding RemoveSelectedServerCredentialCommand}" />
                  </WrapPanel>
                  <ListBox ItemsSource="{Binding ServerCredentials}" SelectedItem="{Binding SelectedServerCredential}" MaxHeight="150">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="2*,*,Auto" ColumnSpacing="10" Margin="2">
                          <TextBlock Text="{Binding Host}" Foreground="{DynamicResource XdmBodyForeground}" />
                          <TextBlock Grid.Column="1" Text="{Binding Username}" Foreground="{DynamicResource XdmSecondarySoftForeground}" />
                          <TextBlock Grid.Column="2" Text="Saved" Foreground="{DynamicResource XdmAccentForeground}" />
                        </Grid>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </StackPanel>
              </Border>

              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <TextBlock Text="{Binding Localization[ui_import_export_and_xdm_8_migration]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                  <Grid ColumnDefinitions="2*,Auto,Auto,Auto" ColumnSpacing="9">
                    <TextBox PlaceholderText="{Binding Localization[ui_settings_file_or_legacy_settings_directory]}" Text="{Binding SettingsTransferPath}" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding Localization[ui_choose_file]}" Click="BrowseSettingsImport_Click" />
                    <Button Grid.Column="2" Classes="secondary" Content="{Binding Localization[ui_choose_folder]}" Click="BrowseSettingsDirectory_Click" />
                    <Button Grid.Column="3" Classes="secondary" Content="{Binding Localization[ui_choose_export]}" Click="BrowseSettingsExport_Click" />
                  </Grid>
                  <CheckBox Content="{Binding Localization[ui_include_proxy_and_server_passwords_in_export]}" IsChecked="{Binding IncludeSecretsInSettingsExport}" />
                  <WrapPanel Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_import_or_migrate]}" Command="{Binding ImportSettingsCommand}" />
                    <Button Classes="secondary" Content="{Binding Localization[ui_export_settings]}" Command="{Binding ExportSettingsCommand}" />
                  </WrapPanel>
                  <TextBlock Text="{Binding SettingsTransferStatus}" TextWrapping="Wrap" Foreground="{DynamicResource XdmAccentForeground}" />
                  <TextBlock Text="{Binding Localization[ui_legacy_import_recognizes_json_java_properties_and_xml_files_modern_expor]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                </StackPanel>
              </Border>

              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                  <TextBlock Text="{Binding Localization[ui_updates]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmPrimarySoftForeground}" />
                  <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap" Foreground="{DynamicResource XdmBodyForeground}" />
                  <ProgressBar Minimum="0" Maximum="1" Value="{Binding UpdateProgress}" Height="8" />
                  <WrapPanel Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_check_for_updates]}" Command="{Binding CheckForUpdatesCommand}" />
                    <Button Margin="0,0,8,0" Classes="primary" Content="{Binding Localization[ui_download_verified_package]}" Command="{Binding DownloadVerifiedUpdateCommand}" />
                    <Button Margin="0,0,8,0" Classes="secondary" Content="{Binding Localization[ui_open_staged_package]}" Command="{Binding OpenStagedUpdateCommand}" />
                    <Button Classes="secondary" Content="{Binding Localization[ui_cancel]}" Command="{Binding CancelUpdateOperationCommand}" />
                  </WrapPanel>
                  <TextBlock Text="{Binding Localization[ui_verified_update_security_note]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                </StackPanel>
              </Border>

              <Button HorizontalAlignment="Left" Classes="primary" Content="{Binding Localization[ui_save_all_settings]}" Command="{Binding SaveSettingsCommand}" />
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer IsVisible="{Binding IsDiagnosticsVisible}">
            <StackPanel Spacing="14">
              <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                  <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Localization[ui_recovery]}" Classes="label" />
                    <TextBlock Text="{Binding RecoveryStatus}" TextWrapping="Wrap" Foreground="{DynamicResource XdmBodyForeground}" />
                    <TextBlock Text="{Binding Localization[ui_launch_with_safe_mode_to_skip_browser_and_scheduler_startup_or_reset_win]}" TextWrapping="Wrap" Foreground="{DynamicResource XdmMutedForeground}" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                  <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Localization[ui_diagnostic_bundle]}" Classes="label" />
                    <TextBlock Text="{Binding DiagnosticBundlePath}" TextWrapping="Wrap" Foreground="{DynamicResource XdmBodyForeground}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Button Classes="primary" Content="{Binding Localization[ui_export_bundle]}" Command="{Binding ExportDiagnosticsCommand}" />
                      <Button Classes="secondary" Content="{Binding Localization[ui_clear_events]}" Command="{Binding ClearDiagnosticsCommand}" />
                    </StackPanel>
                  </StackPanel>
                </Border>
              </Grid>

              <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                  <TextBlock Text="{Binding Localization[ui_recent_events]}" Classes="label" />
                  <ItemsControl ItemsSource="{Binding DiagnosticEvents}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="150,100,180,*" ColumnSpacing="10" Margin="0,3">
                          <TextBlock Text="{Binding Timestamp}" FontFamily="monospace" FontSize="11" Foreground="{DynamicResource XdmMutedForeground}" />
                          <TextBlock Grid.Column="1" Text="{Binding Severity}" FontSize="11" Foreground="{DynamicResource XdmAccentForeground}" />
                          <TextBlock Grid.Column="2" Text="{Binding Code}" FontFamily="monospace" FontSize="11" Foreground="{DynamicResource XdmSecondarySoftForeground}" />
                          <TextBlock Grid.Column="3" Text="{Binding Message}" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource XdmBodyForeground}" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <Border IsVisible="{Binding IsPlaceholderVisible}" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" Margin="30">
              <TextBlock Text="{Binding Localization[ui_text]}" FontSize="38" Foreground="{DynamicResource XdmBrandBrush}" HorizontalAlignment="Center" />
              <TextBlock Text="{Binding Localization[ui_no_page_is_available]}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource XdmBodySoftForeground}" HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
        </Grid>
      </Grid>

      <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
        <TextBlock Text="{Binding RuntimeDescription}" FontSize="11" Foreground="{DynamicResource XdmSubtleDarkForeground}" />
        <TextBlock Grid.Column="1" Text="{Binding Localization[ui_localization_and_accessibility_parity_overlay_20]}" FontSize="11" Foreground="{DynamicResource XdmAccentForeground}" />
      </Grid>
    </Grid>
  </Grid>
  </LayoutTransformControl>
  </ScrollViewer>
</Window>
