<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:XDM.App.Views"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="840"
        x:Class="XDM.App.MainWindow"
        Title="{Binding Localization[ui_xtreme_download_manager]}"
        Icon="/Assets/xdm-logo.ico"
        Width="1280"
        Height="840"
        MinWidth="760"
        MinHeight="680"
        Background="{DynamicResource XdmWindowBackground}"
        KeyDown="MainWindow_KeyDown"
        DragDrop.AllowDrop="True"
        AutomationProperties.Name="{Binding Localization[ui_xtreme_download_manager]}">

  <Window.Resources>
    <SolidColorBrush x:Key="XdmWindowBackground" Color="#0E1116" />
    <SolidColorBrush x:Key="XdmPanelBackground" Color="#11161D" />
    <SolidColorBrush x:Key="XdmPanelAltBackground" Color="#151B23" />
    <SolidColorBrush x:Key="XdmInputBackground" Color="#191F28" />
    <SolidColorBrush x:Key="XdmSecondaryButtonBackground" Color="#1B222C" />
    <SolidColorBrush x:Key="XdmSelectedBackground" Color="#23344B" />
    <SolidColorBrush x:Key="XdmBorderBrush" Color="#242D39" />
    <SolidColorBrush x:Key="XdmInputBorderBrush" Color="#334052" />
    <SolidColorBrush x:Key="XdmBrandBrush" Color="#2F6FEB" />
    <SolidColorBrush x:Key="XdmPrimaryForeground" Color="#F7FAFE" />
    <SolidColorBrush x:Key="XdmPrimarySoftForeground" Color="#F1F5FA" />
    <SolidColorBrush x:Key="XdmBodyForeground" Color="#E7EDF6" />
    <SolidColorBrush x:Key="XdmBodySoftForeground" Color="#E9EEF6" />
    <SolidColorBrush x:Key="XdmSecondaryForeground" Color="#DDE5F2" />
    <SolidColorBrush x:Key="XdmSecondarySoftForeground" Color="#C5D0DE" />
    <SolidColorBrush x:Key="XdmSecondaryDimForeground" Color="#CDD6E2" />
    <SolidColorBrush x:Key="XdmMutedForeground" Color="#94A1B3" />
    <SolidColorBrush x:Key="XdmSubtleForeground" Color="#8795A8" />
    <SolidColorBrush x:Key="XdmSubtleDarkForeground" Color="#8795A8" />
    <SolidColorBrush x:Key="XdmSummaryForeground" Color="#94A1B3" />
    <SolidColorBrush x:Key="XdmDisabledForeground" Color="#7B8DA5" />
    <SolidColorBrush x:Key="XdmAccentForeground" Color="#A9C7FF" />
    <SolidColorBrush x:Key="XdmDangerBrush" Color="#C94F58" />
    <SolidColorBrush x:Key="XdmDangerSoftBrush" Color="#3A2025" />
    <SolidColorBrush x:Key="XdmErrorForeground" Color="#FF9B9B" />
    <SolidColorBrush x:Key="XdmWarningForeground" Color="#F5C66A" />
    <SolidColorBrush x:Key="XdmSuccessForeground" Color="#7ED9A6" />
    <SolidColorBrush x:Key="XdmInfoSoftBrush" Color="#17243A" />
    <SolidColorBrush x:Key="XdmEmptyStateBrush" Color="#121820" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource XdmBodyForeground}" />
    </Style>
    <Style Selector="TextBlock.display">
      <Setter Property="FontSize" Value="28" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource XdmPrimaryForeground}" />
    </Style>
    <Style Selector="TextBlock.page-title">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource XdmPrimaryForeground}" />
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource XdmPrimarySoftForeground}" />
    </Style>
    <Style Selector="TextBlock.card-title">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource XdmSecondaryForeground}" />
    </Style>
    <Style Selector="TextBlock.form-label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{DynamicResource XdmSecondarySoftForeground}" />
    </Style>
    <Style Selector="TextBlock.supporting">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource XdmMutedForeground}" />
    </Style>
    <Style Selector="TextBlock.caption">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource XdmSubtleForeground}" />
    </Style>
    <Style Selector="TextBlock.metric">
      <Setter Property="FontSize" Value="26" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource XdmPrimaryForeground}" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{DynamicResource XdmMutedForeground}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Padding" Value="13,8" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource XdmBrandBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="16,9" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="{DynamicResource XdmSecondaryButtonBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource XdmSecondaryForeground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource XdmBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.quiet">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource XdmSecondarySoftForeground}" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="{DynamicResource XdmDangerSoftBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource XdmErrorForeground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource XdmDangerBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button:focus-visible">
      <Setter Property="BorderBrush" Value="{DynamicResource XdmAccentForeground}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Background" Value="{DynamicResource XdmInputBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource XdmBodyForeground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource XdmInputBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="11,8" />
    </Style>
    <Style Selector="TextBox:focus-visible">
      <Setter Property="BorderBrush" Value="{DynamicResource XdmAccentForeground}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Background" Value="{DynamicResource XdmInputBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource XdmBodyForeground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource XdmInputBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="8,5" />
    </Style>
    <Style Selector="ComboBox:focus-visible">
      <Setter Property="BorderBrush" Value="{DynamicResource XdmAccentForeground}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="NumericUpDown">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Background" Value="{DynamicResource XdmInputBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource XdmBodyForeground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource XdmInputBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="11,6" />
    </Style>
    <Style Selector="NumericUpDown:focus-visible">
      <Setter Property="BorderBrush" Value="{DynamicResource XdmAccentForeground}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource XdmBodyForeground}" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Margin" Value="0,2" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource XdmSelectedBackground}" />
    </Style>
    <Style Selector="ListBox:focus-visible">
      <Setter Property="BorderBrush" Value="{DynamicResource XdmAccentForeground}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="TextBlock.page-title:focus-visible">
      <Setter Property="Background" Value="{DynamicResource XdmSelectedBackground}" />
    </Style>
    <Style Selector="PathIcon.navigation-icon">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="Foreground" Value="{DynamicResource XdmAccentForeground}" />
    </Style>
    <Style Selector="Window.high-contrast">
      <Setter Property="Background" Value="#000000" />
    </Style>
    <Style Selector="Window.high-contrast Border">
      <Setter Property="BorderBrush" Value="#FFFFFF" />
    </Style>
    <Style Selector="Window.high-contrast TextBlock">
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Window.high-contrast Button">
      <Setter Property="BorderBrush" Value="#FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Window.high-contrast TextBox">
      <Setter Property="Background" Value="#000000" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#FFFFFF" />
    </Style>
    <Style Selector="Window.high-contrast ComboBox">
      <Setter Property="Background" Value="#000000" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#FFFFFF" />
    </Style>
    <Style Selector="Window.high-contrast NumericUpDown">
      <Setter Property="Background" Value="#000000" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#FFFFFF" />
    </Style>
    <Style Selector="Window.compact-nav TextBlock.navigation-label">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="Window.compact-nav ListBoxItem">
      <Setter Property="Padding" Value="4,10" />
    </Style>
    <Style Selector="Window.compact-nav Border.navigation-footer">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="Window.compact-nav StackPanel.brand-copy">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="Window.narrow-shell Grid#ContentRoot">
      <Setter Property="Margin" Value="16,14,16,12" />
    </Style>
    <Style Selector="Border.notification-banner">
      <Setter Property="Background" Value="{DynamicResource XdmInfoSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource XdmInputBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style Selector="Border.empty-state">
      <Setter Property="Background" Value="{DynamicResource XdmEmptyStateBrush}" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="24" />
    </Style>
    <Style Selector="Border.error-state">
      <Setter Property="Background" Value="{DynamicResource XdmDangerSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource XdmDangerBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10" />
    </Style>
    <Style Selector="Grid#PageContentHost">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.16" />
        </Transitions>
      </Setter>
    </Style>
  </Window.Styles>

  <LayoutTransformControl x:Name="UiScaleRoot">
    <SplitView x:Name="NavigationSplitView"
               DisplayMode="Inline"
               PanePlacement="Left"
               OpenPaneLength="220"
               CompactPaneLength="60"
               IsPaneOpen="True"
               Background="{DynamicResource XdmWindowBackground}"
               KeyboardNavigation.TabNavigation="Continue">
      <SplitView.Pane>
        <Border Background="{DynamicResource XdmPanelBackground}"
                AutomationProperties.LandmarkType="Navigation"
                AutomationProperties.AccessibilityView="Control"
                BorderBrush="{DynamicResource XdmBorderBrush}"
                BorderThickness="0,0,1,0"
                Padding="12">
          <Grid RowDefinitions="Auto,*,Auto">
            <Grid ColumnDefinitions="36,*" Margin="2,6,2,18">
              <Button Classes="quiet"
                      Width="36"
                      Height="36"
                      Padding="8"
                      Click="ToggleNavigation_Click"
                      ToolTip.Tip="{Binding Localization[ui_application_sections]}"
                      AutomationProperties.Name="{Binding Localization[ui_application_sections]}"
                      AutomationProperties.HelpText="Open or collapse the application navigation pane."
                      AutomationProperties.AcceleratorKey="F6"
                      AutomationProperties.AutomationId="NavigationPaneToggle">
                <PathIcon Data="M3,6 L21,6 M3,12 L21,12 M3,18 L21,18"
                          Width="20"
                          Height="20"
                          Foreground="{DynamicResource XdmSecondaryForeground}" />
              </Button>
              <StackPanel Grid.Column="1" Classes="brand-copy" Spacing="2" Margin="8,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Localization[ui_xdm]}" Classes="display" FontSize="22" />
                <TextBlock Text="{Binding Localization[ui_avalonia_downloader]}" Classes="caption" />
              </StackPanel>
            </Grid>

            <ListBox x:Name="PrimaryNavigation"
                     Grid.Row="1"
                     ItemsSource="{Binding Sections}"
                     AutomationProperties.Name="{Binding Localization[ui_application_sections]}"
                     AutomationProperties.AutomationId="PrimaryNavigation"
                     AutomationProperties.HelpText="Use Up and Down Arrow to choose a section. Ctrl+1 through Ctrl+8 jump directly to a section."
                     AutomationProperties.LandmarkType="Navigation"
                     AutomationProperties.AccessibilityView="Control"
                     SelectedItem="{Binding SelectedSection}"
                     SelectionChanged="PrimaryNavigation_SelectionChanged"
                     Background="Transparent"
                     BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="28,*" ToolTip.Tip="{Binding Title}">
                    <PathIcon Data="{Binding IconData}" Classes="navigation-icon" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Classes="navigation-label" Text="{Binding Title}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource XdmSecondaryForeground}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="2" Classes="navigation-footer" Background="{DynamicResource XdmInputBackground}" CornerRadius="8" Padding="12" Margin="0,14,0,0">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding Localization[ui_browser_capture]}" FontWeight="SemiBold" Foreground="{DynamicResource XdmSecondaryForeground}" />
                <TextBlock Text="{Binding Localization[ui_authenticated_loopback_capture_plus_direct_hls_and_dash_media_probing]}" TextWrapping="Wrap" Classes="caption" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </SplitView.Pane>

      <SplitView.Content>
        <Grid x:Name="ContentRoot" RowDefinitions="Auto,*,Auto" Margin="24,20,24,16">
          <Grid x:Name="PageHeader" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,0,0,16">
            <Button x:Name="ContentNavigationToggle"
                    Classes="quiet"
                    Width="38"
                    Height="38"
                    Padding="8"
                    Click="ToggleNavigation_Click"
                    ToolTip.Tip="{Binding Localization[ui_application_sections]}"
                    AutomationProperties.Name="{Binding Localization[ui_application_sections]}"
                    AutomationProperties.HelpText="Open the application navigation pane."
                    AutomationProperties.AcceleratorKey="F6"
                    AutomationProperties.AutomationId="ContentNavigationToggle">
              <PathIcon Data="M3,6 L21,6 M3,12 L21,12 M3,18 L21,18"
                        Width="20"
                        Height="20"
                        Foreground="{DynamicResource XdmSecondaryForeground}" />
            </Button>
            <Grid Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="12">
              <Border x:Name="SectionIcon" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource XdmSelectedBackground}" VerticalAlignment="Top">
                <PathIcon Data="{Binding SelectedSection.IconData}" Width="21" Height="21" Foreground="{DynamicResource XdmAccentForeground}" HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock x:Name="PageTitleText"
                           Text="{Binding CurrentTitle}"
                           Classes="page-title"
                           Focusable="True"
                           IsTabStop="False"
                           AutomationProperties.HeadingLevel="1"
                           AutomationProperties.AccessibilityView="Content" />
                <TextBlock Text="{Binding CurrentSummary}" Classes="supporting" MaxWidth="760" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Button x:Name="CommandPaletteButton" Classes="quiet" Content="⌘" Width="38" Height="38" ToolTip.Tip="Command palette (Ctrl+K)" Click="CommandPaletteButton_Click">
                <Button.Flyout>
                  <Flyout Placement="BottomEdgeAlignedRight" Opened="CommandPaletteFlyout_Opened" Closed="CommandPaletteFlyout_Closed">
                    <Border Width="430" MaxHeight="520" Padding="8">
                      <Grid RowDefinitions="Auto,*" RowSpacing="8">
                        <TextBox x:Name="CommandPaletteInput" Text="{Binding CommandPaletteQuery}" PlaceholderText="Type a command…" KeyDown="CommandPaletteInput_KeyDown"/>
                        <ListBox x:Name="CommandPaletteList" Grid.Row="1" ItemsSource="{Binding FilteredCommandPaletteItems}" Background="Transparent" BorderThickness="0" DoubleTapped="CommandPaletteList_DoubleTapped">
                          <ListBox.ItemTemplate>
                            <DataTemplate>
                              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Margin="6">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding Shortcut}" Classes="caption" Foreground="{DynamicResource XdmMutedForeground}"/>
                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Description}" Classes="caption" Foreground="{DynamicResource XdmSubtleForeground}" TextWrapping="Wrap"/>
                              </Grid>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>
                      </Grid>
                    </Border>
                  </Flyout>
                </Button.Flyout>
              </Button>

              <Button x:Name="NotificationCenterButton" Classes="quiet" Width="46" Height="38" ToolTip.Tip="Notification center">
                <Grid ColumnDefinitions="Auto,Auto">
                  <TextBlock Text="●" Foreground="{DynamicResource XdmAccentForeground}" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding NotificationCount}" Classes="caption" Margin="4,0,0,0" VerticalAlignment="Center"/>
                </Grid>
                <Button.Flyout>
                  <Flyout Placement="BottomEdgeAlignedRight">
                    <Border Width="440" MaxHeight="560" Padding="8">
                      <Grid RowDefinitions="Auto,*" RowSpacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                          <StackPanel>
                            <TextBlock Text="Notification center" Classes="section-title"/>
                            <TextBlock Text="Recent transfer and application events" Classes="caption" Foreground="{DynamicResource XdmMutedForeground}"/>
                          </StackPanel>
                          <Button Grid.Column="1" Classes="quiet" Content="Clear" Command="{Binding ClearNotificationsCommand}" IsEnabled="{Binding HasNotifications}"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" MaxHeight="460" VerticalScrollBarVisibility="Auto">
                          <ItemsControl ItemsSource="{Binding Notifications}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="8" Padding="10" Margin="0,0,0,7">
                                  <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                    <Button Grid.Column="1" Classes="quiet" Content="×" Click="DismissNotification_Click" Width="28" Height="28" Padding="2"/>
                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Message}" TextWrapping="Wrap" Classes="supporting"/>
                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" Margin="0,5,0,0">
                                      <TextBlock Text="{Binding Severity}" Classes="caption" Foreground="{DynamicResource XdmAccentForeground}"/>
                                      <TextBlock Text="{Binding TimestampText}" Classes="caption" Foreground="{DynamicResource XdmMutedForeground}"/>
                                    </StackPanel>
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </ScrollViewer>
                      </Grid>
                    </Border>
                  </Flyout>
                </Button.Flyout>
              </Button>

              <Border x:Name="OperationStatusBanner" Classes="notification-banner" VerticalAlignment="Center" MaxWidth="390" IsVisible="{Binding IsOperationMessageVisible}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="9">
                  <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource XdmBrandBrush}" VerticalAlignment="Center" />
                  <TextBlock x:Name="OperationStatusText"
                             Grid.Column="1"
                             Text="{Binding OperationMessage}"
                             AutomationProperties.Name="{Binding Localization[ui_operation_status]}"
                             AutomationProperties.AutomationId="OperationStatus"
                             AutomationProperties.LiveSetting="Polite"
                             AutomationProperties.LandmarkType="Region"
                             Foreground="{DynamicResource XdmAccentForeground}"
                             Classes="supporting"
                             TextWrapping="Wrap" />
                  <Button Grid.Column="2"
                          Classes="quiet"
                          Width="30"
                          Height="30"
                          Padding="4"
                          Content="×"
                          Command="{Binding DismissOperationMessageCommand}"
                          ToolTip.Tip="{Binding Localization[ui_dismiss_status]}"
                          AutomationProperties.Name="{Binding Localization[ui_dismiss_status]}"
                          AutomationProperties.AutomationId="DismissOperationStatus" />
                </Grid>
              </Border>
            </StackPanel>
          </Grid>

          <Grid Grid.Row="1" RowDefinitions="Auto,*"
                AutomationProperties.LandmarkType="Main"
                AutomationProperties.AccessibilityView="Control">
            <Grid x:Name="DashboardSummary" ColumnDefinitions="*,*,*" ColumnSpacing="12" IsVisible="{Binding IsDashboardSummaryVisible}"
                  AutomationProperties.Name="Download activity summary"
                  AutomationProperties.LandmarkType="Region">
              <Border Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="10" Padding="15">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Localization[ui_active]}" Classes="label" AutomationProperties.HeadingLevel="2" />
                  <TextBlock Text="{Binding ActiveDownloadCount}" Classes="metric" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="10" Padding="15">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Localization[ui_speed]}" Classes="label" AutomationProperties.HeadingLevel="2" />
                  <TextBlock Text="{Binding AggregateSpeed}" Classes="metric" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="10" Padding="15">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Localization[ui_core]}" Classes="label" AutomationProperties.HeadingLevel="2" />
                  <TextBlock Text="{Binding CoreStatus}" Classes="metric" />
                </StackPanel>
              </Border>
            </Grid>

            <Grid x:Name="PageContentHost"
                  Grid.Row="1"
                  Margin="0,14,0,0"
                  KeyboardNavigation.TabNavigation="Continue"
                  AutomationProperties.Name="{Binding CurrentTitle}"
                  AutomationProperties.LandmarkType="Main"
                  AutomationProperties.AccessibilityView="Control">
              <views:DownloadsView x:Name="DownloadsPage" IsVisible="{Binding IsDownloadsVisible}" />
              <views:RecoveryView IsVisible="{Binding IsRecoveryVisible}" />
              <views:QueuesView IsVisible="{Binding IsQueuesVisible}" />
              <views:SchedulerView IsVisible="{Binding IsSchedulerVisible}" />
              <views:BrowserIntegrationView IsVisible="{Binding IsBrowserIntegrationVisible}" />
              <views:MediaView IsVisible="{Binding IsMediaVisible}" />
              <views:ConversionView IsVisible="{Binding IsConversionVisible}" />
              <views:SettingsView IsVisible="{Binding IsSettingsVisible}" />
              <views:DiagnosticsView IsVisible="{Binding IsDiagnosticsVisible}" />
              <Border IsVisible="{Binding IsPlaceholderVisible}" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" Margin="30">
                  <TextBlock Text="{Binding Localization[ui_text]}" FontSize="38" Foreground="{DynamicResource XdmBrandBrush}" HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding Localization[ui_no_page_is_available]}" Classes="section-title" HorizontalAlignment="Center" />
                </StackPanel>
              </Border>
            </Grid>
          </Grid>

          <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,14,0,0"
                AutomationProperties.LandmarkType="ContentInfo"
                AutomationProperties.AccessibilityView="Control">
            <TextBlock Text="{Binding RuntimeDescription}" Classes="caption" />
            <TextBlock Grid.Column="1" Text="{Binding Localization[ui_localization_and_accessibility_parity_overlay_20]}" Classes="caption" Foreground="{DynamicResource XdmAccentForeground}" />
          </Grid>
        </Grid>
      </SplitView.Content>
    </SplitView>
  </LayoutTransformControl>
</Window>
