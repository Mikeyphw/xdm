<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="XDM.App.MiniWindow"
        Title="XDM Mini"
        Width="430"
        Height="320"
        MinWidth="340"
        MinHeight="220"
        ShowInTaskbar="True"
        Background="{DynamicResource XdmWindowBackground}">
  <Grid RowDefinitions="Auto,Auto,*" Margin="14" RowSpacing="10">
    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
      <StackPanel>
        <TextBlock Text="XDM Mini" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="Compact transfer controls" Classes="caption" Foreground="{DynamicResource XdmMutedForeground}"/>
      </StackPanel>
      <Button Grid.Column="1" Classes="quiet" Content="Open full window" Click="OpenFullWindow_Click"/>
    </Grid>
    <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="8">
      <Border Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="8" Padding="10">
        <StackPanel>
          <TextBlock Text="Active" Classes="caption"/>
          <TextBlock Text="{Binding ActiveDownloadCount}" FontSize="20" FontWeight="SemiBold"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="8" Padding="10">
        <StackPanel>
          <TextBlock Text="Progress" Classes="caption"/>
          <TextBlock Text="{Binding AggregateProgressText}" FontSize="20" FontWeight="SemiBold"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Background="{DynamicResource XdmPanelAltBackground}" CornerRadius="8" Padding="10">
        <StackPanel>
          <TextBlock Text="Speed" Classes="caption"/>
          <TextBlock Text="{Binding AggregateSpeed}" FontSize="20" FontWeight="SemiBold"/>
        </StackPanel>
      </Border>
    </Grid>
    <Border Grid.Row="2" Background="{DynamicResource XdmPanelBackground}" CornerRadius="8" Padding="8">
      <Grid RowDefinitions="*,Auto" RowSpacing="8">
        <ListBox ItemsSource="{Binding MiniDownloads}" SelectedItem="{Binding SelectedDownload}" Background="Transparent" BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Margin="4">
                <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusText}" Foreground="{DynamicResource XdmAccentForeground}"/>
                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" Height="4" Margin="0,5,0,0"/>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <WrapPanel Grid.Row="1" HorizontalAlignment="Right">
          <Button Margin="0,0,6,0" Classes="secondary" Content="Pause" Command="{Binding PauseSelectedCommand}"/>
          <Button Margin="0,0,6,0" Classes="secondary" Content="Resume" Command="{Binding ResumeSelectedCommand}"/>
          <Button Classes="danger" Content="Cancel" Command="{Binding CancelSelectedCommand}"/>
        </WrapPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
