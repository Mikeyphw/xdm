<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="XDM.App.Views.BrowserIntegrationView"
             mc:Ignorable="d"
             KeyboardNavigation.TabNavigation="Continue"
             AutomationProperties.LandmarkType="Main"
             AutomationProperties.AccessibilityView="Control">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="14">
      <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
        <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="16" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding Localization[ui_capture_service]}" Classes="label"/>
            <TextBlock Text="{Binding BrowserIntegrationStatus}" Classes="card-title" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding BrowserEndpoint}" Classes="caption" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="16" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding Localization[ui_extension_health]}" Classes="label"/>
            <TextBlock Text="{Binding BrowserExtensionSummary}" Classes="card-title" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding BrowserLastHealth}" Classes="caption" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="2" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="16" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding Localization[ui_protocol_compatibility]}" Classes="label"/>
            <TextBlock Text="{Binding BrowserCompatibilityStatus}" Classes="card-title" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding BrowserPermissionSummary}" Classes="caption" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
      </Grid>

      <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="20" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
        <StackPanel Spacing="13" MaxWidth="900" HorizontalAlignment="Left">
          <TextBlock Text="{Binding Localization[ui_browser_integration_health]}" Classes="section-title" AutomationProperties.HeadingLevel="2"/>
          <TextBlock Text="{Binding Localization[ui_browser_security_description]}" Classes="supporting" TextWrapping="Wrap"/>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="14" RowSpacing="8">
            <TextBlock Text="{Binding Localization[ui_endpoint]}" Classes="label" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding BrowserEndpoint}" IsReadOnly="True" AutomationProperties.Name="Browser capture endpoint" AutomationProperties.AutomationId="BrowserIntegration_BrowserEndpoint"/>
            <TextBlock Grid.Row="1" Text="{Binding Localization[ui_token]}" Classes="label" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BrowserAuthenticationToken}" IsReadOnly="True" AutomationProperties.Name="Browser authentication token" AutomationProperties.AutomationId="BrowserIntegration_BrowserAuthenticationToken"/>
          </Grid>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="primary" Content="{Binding Localization[ui_refresh_diagnostics]}" Command="{Binding RefreshBrowserDiagnosticsCommand}" AutomationProperties.AutomationId="BrowserIntegration_RefreshDiagnostics"/>
            <Button Classes="secondary" Content="{Binding Localization[ui_restart_capture_service]}" Command="{Binding RestartBrowserIntegrationCommand}"/>
            <Button Classes="secondary" Content="{Binding Localization[ui_probe_url_from_downloads]}" Command="{Binding ProbeEnteredUrlCommand}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
        <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
          <StackPanel Spacing="10">
            <TextBlock Text="{Binding Localization[ui_native_host_registration]}" Classes="section-title" AutomationProperties.HeadingLevel="2"/>
            <TextBlock Text="{Binding BrowserHostStatus}" TextWrapping="Wrap" Foreground="{DynamicResource XdmSecondarySoftForeground}"/>
            <TextBlock Text="{Binding Localization[ui_chromium_extension_ids]}" Classes="label"/>
            <TextBox PlaceholderText="{Binding Localization[ui_chromium_extension_id_s_comma_separated_firefox_is_automatic]}" Text="{Binding BrowserExtensionId}" AutomationProperties.Name="Chromium extension IDs" AutomationProperties.AutomationId="BrowserIntegration_ChromiumExtensionIds"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="primary" Content="{Binding Localization[ui_install_repair]}" Command="{Binding RepairBrowserHostCommand}"/>
              <Button Classes="danger" Content="{Binding Localization[ui_uninstall]}" Command="{Binding UninstallBrowserHostCommand}"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
          <StackPanel Spacing="10">
            <TextBlock Text="{Binding Localization[ui_extension_permissions_capabilities]}" Classes="section-title" AutomationProperties.HeadingLevel="2"/>
            <TextBlock Text="{Binding BrowserPermissionSummary}" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding BrowserCapabilitiesSummary}" Classes="supporting" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding Localization[ui_extension_permissions_hint]}" Classes="caption" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
      </Grid>

      <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
        <Border Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding Localization[ui_last_capture]}" Classes="label"/>
            <TextBlock Text="{Binding LastBrowserCapture}" TextWrapping="Wrap" Foreground="{DynamicResource XdmBodyForeground}"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Background="{DynamicResource XdmPanelBackground}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource XdmBorderBrush}" BorderThickness="1">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding Localization[ui_media_probe]}" Classes="label"/>
            <TextBlock Text="{Binding LastMediaProbe}" TextWrapping="Wrap" Foreground="{DynamicResource XdmBodyForeground}"/>
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
