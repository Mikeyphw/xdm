<MPD xmlns="urn:mpeg:dash:schema:mpd:2011" type="static" mediaPresentationDuration="PT6S">
  <Period duration="PT6S">
    <AdaptationSet contentType="video" mimeType="video/mp4" codecs="avc1.4d401f">
      <SegmentTemplate timescale="1" initialization="init-$RepresentationID$.mp4" media="chunk-$RepresentationID$-$Number%05d$.m4s" startNumber="1">
        <SegmentTimeline><S t="0" d="2" r="2" /></SegmentTimeline>
      </SegmentTemplate>
      <Representation id="v1080" bandwidth="2800000" width="1920" height="1080" frameRate="30" />
    </AdaptationSet>
    <AdaptationSet contentType="audio" mimeType="audio/mp4" lang="en">
      <Representation id="a128" bandwidth="128000">
        <SegmentList>
          <Initialization sourceURL="audio-init.mp4" />
          <SegmentURL media="audio-1.m4s" />
          <SegmentURL media="audio-2.m4s" />
        </SegmentList>
      </Representation>
    </AdaptationSet>
  </Period>
</MPD>
